{
  "version": 2,
  "buildCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile && pnpm --filter @workspace/hekayaty build",
  "outputDirectory": "artifacts/hekayaty/dist/public",
  "installCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
