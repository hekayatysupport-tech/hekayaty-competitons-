# =====================================================
# Hekayaty Awards Website — Environment Variables
# =====================================================
# Copy this file and fill in the values.
# For Vercel: add these in Project Settings → Environment Variables

# --- Supabase (Required) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Backend API URL (Required for novel uploads & admin login) ---
# Point this to your deployed api-server (Railway, Render, etc.)
# Example: https://hekayaty-api.railway.app
VITE_API_URL=https://your-api-server.railway.app

# =====================================================
# The following vars are for the API SERVER only
# (not needed in Vercel frontend deployment)
# =====================================================

# Supabase Service Role Key (for server-side DB writes)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telegram Bot Token & Channel ID
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHANNEL_ID=your_channel_id

# Admin Secret (for first-time admin setup)
ADMIN_SECRET=your_admin_secret

PORT=3001
