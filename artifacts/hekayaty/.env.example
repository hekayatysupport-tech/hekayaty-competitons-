# ============================================================
# HEKAYATY AWARDS 2026 - ENVIRONMENT VARIABLES
# ============================================================
# 
# Instructions:
# 1. Go to your Supabase project → Project Settings → API
# 2. Copy "Project URL" and paste it as VITE_SUPABASE_URL
# 3. Copy "anon / public" key and paste it as VITE_SUPABASE_ANON_KEY
# 4. Set VITE_API_URL to wherever your api-server is running
# 5. Rename this file to .env (remove the .example suffix)
# ============================================================

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# API Server URL (used for novel file uploads to Telegram)
VITE_API_URL=http://localhost:3001
